{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chapter Frontmatter",
  "type": "object",
  "required": [
    "id",
    "title",
    "slug",
    "hero"
  ],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 0
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "created": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated": {
      "type": [
        "string",
        "null"
      ]
    },
    "hero": {
      "type": "object",
      "required": [
        "image"
      ],
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1
        },
        "themeColor": {
          "type": [
            "string",
            "null"
          ]
        },
        "focalPoint": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "left",
            "center",
            "right",
            null
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
